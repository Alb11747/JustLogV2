# Copy this file to .env if you want a clean local starting point.
# The committed .env is safe to use as-is for Compose defaults.

JUSTLOG_PUBLIC_PORT=8026

# Optional import-folder compatibility flags.
JUSTLOG_IMPORT_HOST_DIR=./data/import-folder
JUSTLOG_IMPORT_FOLDER=/import-folder
JUSTLOG_LEGACY_TXT_MODE=missing_only
JUSTLOG_LEGACY_TXT_CHECK_EACH_REQUEST=0
JUSTLOG_IMPORT_DELETE_RAW=0
JUSTLOG_IMPORT_DELETE_ALREADY_IMPORTED_RAW=1
JUSTLOG_IMPORT_DELETE_RECONSTRUCTED=0
JUSTLOG_IMPORT_DELETE_ALREADY_IMPORTED_RECONSTRUCTED=0
JUSTLOG_IMPORT_MAX_COMPRESS_THREADS=4

# Optional missed-message backfill from Robotty recent-messages.
JUSTLOG_RECENT_MESSAGES_ENABLED=0
JUSTLOG_RECENT_MESSAGES_URL=https://recent-messages.robotty.de/api/v2/recent-messages
JUSTLOG_RECENT_MESSAGES_LIMIT=800

# Optional reconciliation / validation flags.
JUSTLOG_DEBUG=0
JUSTLOG_DEBUG_COMPARE_URL=
JUSTLOG_DEBUG_TRUSTED_COMPARE_URL=
JUSTLOG_DEBUG_FALLBACK_TRUSTED_API=0
JUSTLOG_DEBUG_VALIDATE_CONSISTENCY_ON_STARTUP=
JUSTLOG_DEBUG_VALIDATE_CONSISTENCY_ON_STARTUP_IGNORE_LAST_VALIDATED=0
